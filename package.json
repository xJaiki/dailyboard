{
  "name": "dailyboard",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev:server": "node --watch server/index.js",
    "dev:client": "vite",
    "start": "concurrently -n server,client \"npm:dev:server\" \"npm:dev:client\"",
    "build": "vite build",
    "serve": "node server/index.js",
    "test": "for f in src/lib/*.test.js; do node \"$f\" || exit 1; done"
  },
  "dependencies": {
    "better-sqlite3": "^12.11.1",
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^8.2.2",
    "vite": "^5.4.0"
  }
}
